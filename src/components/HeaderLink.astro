---
import type {HTMLAttributes} from 'astro/types';

type Props = HTMLAttributes<'a'>;

const {href, class: className, ...props} = Astro.props;
const pathname = Astro.url.pathname;

// Strip trailing slash for comparison (except root "/")
const normalize = (p: string) => (p !== '/' && p.endsWith('/') ? p.slice(0, -1) : p);
const normalizedHref = normalize(href ? String(href) : '');
const normalizedPath = normalize(pathname);

// isBlogGalaxy: explicit /blog/galaxy or any hypothetical sub-route
const isBlogGalaxy = normalizedPath === '/blog/galaxy' || normalizedPath.startsWith('/blog/galaxy/');

const isActive =
  normalizedHref === normalizedPath ||
  (normalizedHref === '/blog' && normalizedPath.startsWith('/blog/') && !isBlogGalaxy) ||
  (normalizedHref === '/tags' && normalizedPath.startsWith('/tags/'));
---

<a
  href={href}
  class:list={[
    'px-4 py-2 rounded-lg hover:text-misaka-blue transition-all duration-200',
    'hover:bg-misaka-circuit/10 font-medium',
    className,
    {
      'bg-misaka-blue/20 text-misaka-blue border-b-2 border-misaka-blue': isActive
    }
  ]}
  style={!isActive ? 'color: var(--text-secondary);' : ''}
  {...props}
>
  <slot/>
</a>
