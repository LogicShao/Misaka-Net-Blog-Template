---
import type {CollectionEntry} from 'astro:content';

export interface Props {
  prevPost?: CollectionEntry<'blog'>;
  nextPost?: CollectionEntry<'blog'>;
}

const {prevPost, nextPost} = Astro.props;
---

{(prevPost || nextPost) && (
<div class="network-panel my-12">
  <h3 class="text-sm font-mono text-misaka-circuit mb-4">// Navigation</h3>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- Previous Post -->
    {prevPost ? (
      <a
        href={`/blog/${prevPost.data.slug || prevPost.id}/`}
        class="group flex flex-col p-4 rounded-lg border transition-all duration-300 hover:border-misaka-blue hover:shadow-lg"
        style={`border-color: var(--border-color); background-color: var(--bg-secondary);`}
      >
        <div class="flex items-center gap-2 text-sm font-mono mb-2" style="color: var(--text-muted);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span>上一篇</span>
        </div>
        <h4
          class="text-base font-semibold group-hover:text-misaka-blue transition-colors duration-300 line-clamp-2"
          style="color: var(--text-primary);">
          {prevPost.data.title}
        </h4>
        {prevPost.data.description && (
          <p class="text-sm mt-2 line-clamp-2" style="color: var(--text-secondary);">
            {prevPost.data.description}
          </p>
        )}
      </a>
    ) : (
      <div
        class="flex flex-col p-4 rounded-lg border opacity-50"
        style={`border-color: var(--border-color); background-color: var(--bg-secondary);`}>
        <div class="flex items-center gap-2 text-sm font-mono mb-2" style="color: var(--text-muted);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span>上一篇</span>
        </div>
        <p class="text-sm" style="color: var(--text-muted);">没有更早的文章了</p>
      </div>
    )}

    <!-- Next Post -->
    {nextPost ? (
      <a
        href={`/blog/${nextPost.data.slug || nextPost.id}/`}
        class="group flex flex-col p-4 rounded-lg border transition-all duration-300 hover:border-misaka-blue hover:shadow-lg text-right md:text-left"
        style={`border-color: var(--border-color); background-color: var(--bg-secondary);`}
      >
        <div
          class="flex items-center justify-end md:justify-start gap-2 text-sm font-mono mb-2 md:flex-row-reverse" style="color: var(--text-muted);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span>下一篇</span>
        </div>
        <h4
          class="text-base font-semibold group-hover:text-misaka-circuit transition-colors duration-300 line-clamp-2"
          style="color: var(--text-primary);">
          {nextPost.data.title}
        </h4>
        {nextPost.data.description && (
          <p class="text-sm mt-2 line-clamp-2" style="color: var(--text-secondary);">
            {nextPost.data.description}
          </p>
        )}
      </a>
    ) : (
      <div
        class="flex flex-col p-4 rounded-lg border opacity-50"
        style={`border-color: var(--border-color); background-color: var(--bg-secondary);`}>
        <div class="flex items-center justify-end gap-2 text-sm font-mono mb-2" style="color: var(--text-muted);">
          <span>下一篇</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
        <p class="text-sm text-right" style="color: var(--text-muted);">没有更新的文章了</p>
      </div>
    )}
  </div>
</div>
  )}
