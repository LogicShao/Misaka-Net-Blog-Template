---
import type {GetStaticPaths} from 'astro';
import Layout from '../../layouts/Layout.astro';
import Pagination from '../../components/Pagination.astro';
import {getSortedDailyPosts} from '../../utils/daily';

export const getStaticPaths = (async ({paginate}) => {
  const allPosts = await getSortedDailyPosts();
  return paginate(allPosts, {
    pageSize: 30,
  });
}) satisfies GetStaticPaths;

const {page} = Astro.props;
---

<Layout
  title={`日报归档${page.currentPage > 1 ? ` - 第 ${page.currentPage} 页` : ''} - Misaka Network`}
  description="每日技术资讯整理归档"
>
  <div class="mb-12">
    <h1 class="text-4xl md:text-5xl font-bold mb-4" style="color: var(--text-primary);">
      日报归档
    </h1>
    <p class="text-lg font-mono" style="color: var(--text-muted);">
      // Total: <span class="text-misaka-blue">{page.total}</span> 期
      {page.currentPage > 1 && (
        <span class="ml-4">
          // Page: <span class="text-misaka-circuit">{page.currentPage}</span>
        </span>
      )}
    </p>
    <div class="divider-circuit mt-6"></div>
  </div>

  <div class="space-y-6">
    {
      page.data.map((post) => {
        const d = post.data.date;
        const dateStr = d ? new Date(d).toISOString().slice(0, 10) : '';
        return (
          <a href={`/daily/${post.id}`} class="card-misaka block group">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-3 mb-2">
                  {dateStr && (
                    <time class="text-sm font-mono text-misaka-circuit" datetime={dateStr}>
                      {dateStr}
                    </time>
                  )}
                </div>
                <h2 class="text-xl font-bold group-hover:text-misaka-blue transition-colors duration-200 mb-2" style="color: var(--text-primary);">
                  日报 {dateStr}
                </h2>
                {post.data.summary && (
                  <p class="text-sm font-mono line-clamp-2" style="color: var(--text-muted);">
                    {post.data.summary}
                  </p>
                )}
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {post.data.tags.map(tag => (
                      <span class="tag-misaka text-xs">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        );
      })
    }

    {page.data.length === 0 && (
      <div class="network-panel text-center py-12">
        <p class="text-lg" style="color: var(--text-muted);">
          暂无日报
        </p>
      </div>
    )}
  </div>

  {page.lastPage > 1 && (
    <div class="mt-12">
      <Pagination
        currentPage={page.currentPage}
        totalPages={page.lastPage}
        baseUrl="/daily"
      />
    </div>
  )}
</Layout>
