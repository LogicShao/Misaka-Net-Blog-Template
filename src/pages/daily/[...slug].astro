---
import {getCollection, type CollectionEntry, render} from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Tag from '../../components/Tag.astro';

export async function getStaticPaths() {
  const posts = await getCollection('daily');
  return posts.map((post: CollectionEntry<'daily'>) => ({
    params: {slug: post.id},
    props: post,
  }));
}

type Props = CollectionEntry<'daily'>;
const post = Astro.props;
const {Content} = await render(post);
const {date, summary, tags = []} = post.data;
---

<Layout title={`${date ? new Date(date).toISOString().slice(0, 10) : '日报'} - Misaka Network`} description={summary}>
  <article class="max-w-3xl mx-auto">
    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-3" style="color: var(--text-primary);">
        日报 {date && new Date(date).toISOString().slice(0, 10)}
      </h1>
      {date && (
        <div class="flex items-center space-x-4 text-sm font-mono mb-4" style="color: var(--text-muted);">
          <FormattedDate date={date}/>
        </div>
      )}
      {summary && (
        <p class="text-lg font-mono" style="color: var(--text-secondary);">
          {summary}
        </p>
      )}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => <Tag tag={tag}/>)}
        </div>
      )}
      <div class="divider-circuit mt-6"></div>
    </header>

    <!-- Content -->
    <div class="prose" style="color: var(--text-secondary);">
      <Content/>
    </div>
  </article>
</Layout>
